# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to GitHub.

# --- General ---
APP_NAME=SkillNova AI Internship Management System
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# --- Database ---
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./skillnova.db
# Or PostgreSQL (uncomment and configure if used):
# DATABASE_URL=postgresql://user:password@localhost:5432/skillnova

# --- AI / LLM Providers ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Vector Database (for RAG-based modules) ---
VECTOR_DB_PROVIDER=chromadb
VECTOR_DB_PATH=./vector_store

# --- CORS ---
ALLOWED_ORIGINS=*

# --- Frontend ---
BACKEND_URL=http://127.0.0.1:8000
